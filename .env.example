# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Site URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://petapoio.com.br
# For local dev: NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Stripe ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Platform commission % (e.g. 20 = 20%)
STRIPE_PLATFORM_FEE_PERCENT=20

# ─── Daily.co (Video) ─────────────────────────────────────────────────────────
DAILY_API_KEY=your_daily_api_key_here

# ─── Resend (Email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=no-reply@petapoio.com.br

# ─── Shopify Storefront (Loja) ────────────────────────────────────────────────
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=petapoio.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token

# ─── Cal.com (Agendamento) ────────────────────────────────────────────────────
CAL_COM_API_KEY=your_cal_com_api_key

# ─── WhatsApp (Twilio) ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886